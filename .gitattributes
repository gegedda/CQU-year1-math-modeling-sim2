# Auto detect text files and perform LF normalization
* text=auto

# Python files
*.py text eol=lf

# Markdown files
*.md text eol=lf

# CSV data files
*.csv text eol=lf

# Batch scripts (must be CRLF on Windows)
*.bat text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.pdf binary
*.zip binary
